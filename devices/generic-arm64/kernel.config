#
# LumiOS Kernel Config - generic-arm64 (QEMU virt)
# LumiOS 内核配置 - generic-arm64 (QEMU virt)
#
# Based on Linux 6.12 defconfig for ARM64 QEMU virt platform.
# 基于 Linux 6.12 ARM64 QEMU virt 平台 defconfig。
#

# === Architecture / 架构 ===
CONFIG_ARM64=y
CONFIG_64BIT=y

# === Performance optimizations / 性能优化 ===
CONFIG_PREEMPT=y
CONFIG_HZ_300=y
CONFIG_NO_HZ_FULL=y
CONFIG_SCHED_AUTOGROUP=y
CONFIG_SCHED_CORE=y
CONFIG_CGROUP_SCHED=y

# === Memory / 内存 ===
CONFIG_ZRAM=y
CONFIG_ZSMALLOC=y
CONFIG_ZSWAP=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_COMPACTION=y

# === Cgroups v2 / Cgroups v2 ===
CONFIG_CGROUPS=y
CONFIG_CGROUP_V2=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_BPF=y

# === Namespaces (for Android container) / 命名空间（Android 容器） ===
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUP_NS=y

# === Security / 安全 ===
CONFIG_RANDOMIZE_BASE=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y

# === Filesystem / 文件系统 ===
CONFIG_EXT4_FS=y
CONFIG_F2FS_FS=y
CONFIG_EROFS_FS=y
CONFIG_TMPFS=y
CONFIG_OVERLAY_FS=y
CONFIG_FUSE_FS=y
CONFIG_SQUASHFS=y
CONFIG_VFAT_FS=y

# === Block I/O / 块 I/O ===
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_CRYPT=y
CONFIG_IOSCHED_BFQ=y
CONFIG_BFQ_GROUP_IOSCHED=y
CONFIG_DEFAULT_BFQ=y

# === Network / 网络 ===
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NFT_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_BRIDGE=m

# === Virtio devices (QEMU) / Virtio 设备 (QEMU) ===
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_INPUT=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_VIRTIO_FS=y

# === DRM/GPU / 图形 ===
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_GEM_SHMEM_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y

# === Input / 输入 ===
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_TOUCHSCREEN=y

# === Serial console / 串口终端 ===
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# === Android binder (for compat layer) / Android binder（兼容层） ===
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ASHMEM=y

# === Misc / 杂项 ===
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_INOTIFY_USER=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
